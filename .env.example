# ============================================
# 🚀 STAR-DOC — Variables de Entorno
# Sistema de Inteligencia Legal con IA
# ============================================
# Copia este archivo como .env y completa los valores.
# cp .env.example .env

# ============================================
# 🔐 SEGURIDAD & AUTENTICACIÓN
# ============================================
# Clave secreta para firmar tokens JWT. Genera una con:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu_clave_secreta_jwt_aqui

# Entorno de ejecución: development | production
# En production se valida que SECRET_KEY no sea la por defecto.
ENV=development

# URL base de la aplicación (cambia en producción)
BASE_URL=http://localhost:8000

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000

# ============================================
# 🤖 GEMINI AI (Motor de IA Principal)
# ============================================
# Obtén tu API key en: https://aistudio.google.com/app/apikey
# STAR-DOC soporta múltiples claves para rotación automática
# y balanceo de carga (rate limiting). Mínimo 1 clave requerida.
GEMINI_API_KEY=tu_gemini_api_key_aqui
GEMINI_API_KEY_2=tu_segunda_gemini_api_key_aqui
GEMINI_API_KEY_3=tu_tercera_gemini_api_key_aqui
# GEMINI_API_KEY_4=...hasta GEMINI_API_KEY_10 (opcional)

# ============================================
# 🔍 BRAVE SEARCH (Búsqueda Jurisprudencial Web)
# ============================================
# Obtén tu API key gratuita en: https://brave.com/search/api/
# Se usa para buscar jurisprudencia actualizada en tiempo real.
BRAVE_API_KEY=tu_brave_api_key_aqui

# ============================================
# 🗄️ BASE DE DATOS POSTGRESQL
# ============================================
# URL de conexión principal (asyncpg para operaciones asíncronas)
DATABASE_URL=postgresql+asyncpg://postgres:tu_password@localhost:5432/star_doc

# Configuración granular (alternativa a DATABASE_URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=star_doc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_password_postgres

# ============================================
# 📧 SERVIDOR DE EMAIL (SMTP)
# ============================================
# Configuración para envío de correos (notificaciones, firmas, etc.)
# Para Gmail: habilita "Contraseñas de aplicación" en tu cuenta Google.
# https://myaccount.google.com/apppasswords
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion_gmail
SMTP_FROM_EMAIL=tu_email@gmail.com
SMTP_FROM_NAME=Star-Doc Assistant
SMTP_USE_TLS=True
SMTP_USE_SSL=False

# ============================================
# 📅 GOOGLE CALENDAR API (Citas y Agenda)
# ============================================
# Configura un proyecto en Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Habilita la API de Google Calendar y crea credenciales OAuth 2.0.
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALENDAR_ID=tu_email@gmail.com
GOOGLE_REFRESH_TOKEN=tu_google_refresh_token

# ============================================
# 📌 PINATA (IPFS Cloud Pinning)
# ============================================
# Regístrate en: https://app.pinata.cloud/
# Crea API keys en: https://app.pinata.cloud/developers/api-keys
PINATA_API_KEY=tu_pinata_api_key
PINATA_API_SECRET=tu_pinata_api_secret
PINATA_JWT=tu_pinata_jwt_token
PINATA_GATEWAY=https://gateway.pinata.cloud

# ============================================
# ⚡ REDIS (Cache, Métricas y Circuit Breaker)
# ============================================
# Instala Redis localmente: https://redis.io/download
# O usa Docker: docker run -d -p 6379:6379 redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ============================================
# 📹 JITSI MEET (Videoconferencias Legales)
# ============================================
# Por defecto usa el servidor público meet.jit.si (sin JWT).
# Para un servidor privado, configura JWT.
JITSI_DOMAIN=meet.jit.si
JITSI_USE_JWT=False
JITSI_APP_ID=
JITSI_SECRET=
